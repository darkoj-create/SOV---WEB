<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.SpeleoV1">

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/provider_paths" />
        </provider>

        <service
            android:name=".util.TrackingForegroundService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.SpeleoV1.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- SOV field package association: opening .sovpkg offers SOV and imports the package. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="file" android:pathPattern=".*\\.sovpkg" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" android:pathPattern=".*\\.sovpkg" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" android:mimeType="application/vnd.sov.field-package" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" android:mimeType="application/zip" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" android:mimeType="application/octet-stream" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/vnd.sov.field-package" />
                <data android:mimeType="application/zip" />
                <data android:mimeType="application/octet-stream" />
            </intent-filter>


            <!-- SOV v1.7.96 external file open support: make supported field/map files appear in Android "Open with SOV" from Drive, WhatsApp, Files, etc. -->
            <!-- Extension-based VIEW filters for file:// providers that expose paths. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="file" android:pathPattern=".*\.kml" />
                <data android:scheme="file" android:pathPattern=".*\.kmz" />
                <data android:scheme="file" android:pathPattern=".*\.gpx" />
                <data android:scheme="file" android:pathPattern=".*\.geojson" />
                <data android:scheme="file" android:pathPattern=".*\.json" />
                <data android:scheme="file" android:pathPattern=".*\.xml" />
                <data android:scheme="file" android:pathPattern=".*\.csv" />
                <data android:scheme="file" android:pathPattern=".*\.xlsx" />
                <data android:scheme="file" android:pathPattern=".*\.xlsm" />
                <data android:scheme="file" android:pathPattern=".*\.xls" />
                <data android:scheme="file" android:pathPattern=".*\.gpkg" />
                <data android:scheme="file" android:pathPattern=".*\.geopackage" />
                <data android:scheme="file" android:pathPattern=".*\.sqlite" />
                <data android:scheme="file" android:pathPattern=".*\.db" />
                <data android:scheme="file" android:pathPattern=".*\.tif" />
                <data android:scheme="file" android:pathPattern=".*\.tiff" />
                <data android:scheme="file" android:pathPattern=".*\.mbtiles" />
                <data android:scheme="file" android:pathPattern=".*\.sovpkg" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" android:pathPattern=".*\.kml" />
                <data android:scheme="content" android:pathPattern=".*\.kmz" />
                <data android:scheme="content" android:pathPattern=".*\.gpx" />
                <data android:scheme="content" android:pathPattern=".*\.geojson" />
                <data android:scheme="content" android:pathPattern=".*\.json" />
                <data android:scheme="content" android:pathPattern=".*\.xml" />
                <data android:scheme="content" android:pathPattern=".*\.csv" />
                <data android:scheme="content" android:pathPattern=".*\.xlsx" />
                <data android:scheme="content" android:pathPattern=".*\.xlsm" />
                <data android:scheme="content" android:pathPattern=".*\.xls" />
                <data android:scheme="content" android:pathPattern=".*\.gpkg" />
                <data android:scheme="content" android:pathPattern=".*\.geopackage" />
                <data android:scheme="content" android:pathPattern=".*\.sqlite" />
                <data android:scheme="content" android:pathPattern=".*\.db" />
                <data android:scheme="content" android:pathPattern=".*\.tif" />
                <data android:scheme="content" android:pathPattern=".*\.tiff" />
                <data android:scheme="content" android:pathPattern=".*\.mbtiles" />
                <data android:scheme="content" android:pathPattern=".*\.sovpkg" />
            </intent-filter>

            <!-- MIME-based VIEW filters used by Google Drive, WhatsApp and Android Files for content:// URIs. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" android:mimeType="application/vnd.google-earth.kml+xml" />
                <data android:scheme="content" android:mimeType="application/vnd.google-earth.kmz" />
                <data android:scheme="content" android:mimeType="application/gpx+xml" />
                <data android:scheme="content" android:mimeType="application/geo+json" />
                <data android:scheme="content" android:mimeType="application/json" />
                <data android:scheme="content" android:mimeType="application/xml" />
                <data android:scheme="content" android:mimeType="text/xml" />
                <data android:scheme="content" android:mimeType="text/plain" />
                <data android:scheme="content" android:mimeType="text/csv" />
                <data android:scheme="content" android:mimeType="application/csv" />
                <data android:scheme="content" android:mimeType="application/vnd.ms-excel" />
                <data android:scheme="content" android:mimeType="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" />
                <data android:scheme="content" android:mimeType="application/vnd.ms-excel.sheet.macroEnabled.12" />
                <data android:scheme="content" android:mimeType="application/geopackage+sqlite3" />
                <data android:scheme="content" android:mimeType="application/x-sqlite3" />
                <data android:scheme="content" android:mimeType="application/vnd.sqlite3" />
                <data android:scheme="content" android:mimeType="application/x-mbtiles" />
                <data android:scheme="content" android:mimeType="image/tiff" />
                <data android:scheme="content" android:mimeType="application/zip" />
                <data android:scheme="content" android:mimeType="application/x-zip-compressed" />
                <data android:scheme="content" android:mimeType="application/x-zip" />
                <data android:scheme="content" android:mimeType="application/x-shapefile" />
                <data android:scheme="content" android:mimeType="application/x-gpx+xml" />
                <data android:scheme="content" android:mimeType="application/x-gpx" />
                <data android:scheme="content" android:mimeType="application/x-kml" />
                <data android:scheme="content" android:mimeType="application/vnd.geo+json" />
                <data android:scheme="content" android:mimeType="application/x-geojson" />
                <data android:scheme="content" android:mimeType="application/octet-stream" />
                <data android:scheme="content" android:mimeType="application/vnd.sov.field-package" />
            </intent-filter>

            <!-- Share-sheet support: WhatsApp/Drive often send files via ACTION_SEND instead of ACTION_VIEW. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/vnd.google-earth.kml+xml" />
                <data android:mimeType="application/vnd.google-earth.kmz" />
                <data android:mimeType="application/gpx+xml" />
                <data android:mimeType="application/geo+json" />
                <data android:mimeType="application/json" />
                <data android:mimeType="application/xml" />
                <data android:mimeType="text/xml" />
                <data android:mimeType="text/plain" />
                <data android:mimeType="text/csv" />
                <data android:mimeType="application/csv" />
                <data android:mimeType="application/vnd.ms-excel" />
                <data android:mimeType="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" />
                <data android:mimeType="application/vnd.ms-excel.sheet.macroEnabled.12" />
                <data android:mimeType="application/geopackage+sqlite3" />
                <data android:mimeType="application/x-sqlite3" />
                <data android:mimeType="application/vnd.sqlite3" />
                <data android:mimeType="application/x-mbtiles" />
                <data android:mimeType="image/tiff" />
                <data android:mimeType="application/zip" />
                <data android:mimeType="application/x-zip-compressed" />
                <data android:mimeType="application/x-zip" />
                <data android:mimeType="application/x-shapefile" />
                <data android:mimeType="application/x-gpx+xml" />
                <data android:mimeType="application/x-gpx" />
                <data android:mimeType="application/x-kml" />
                <data android:mimeType="application/vnd.geo+json" />
                <data android:mimeType="application/x-geojson" />
                <data android:mimeType="application/octet-stream" />
                <data android:mimeType="application/vnd.sov.field-package" />
            </intent-filter>

            <!-- SHP/ZIP path fallback for file managers that expose real file names. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="file" android:pathPattern=".*\.shp" />
                <data android:scheme="file" android:pathPattern=".*\.zip" />
                <data android:scheme="content" android:pathPattern=".*\.shp" />
                <data android:scheme="content" android:pathPattern=".*\.zip" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/vnd.google-earth.kml+xml" />
                <data android:mimeType="application/vnd.google-earth.kmz" />
                <data android:mimeType="application/gpx+xml" />
                <data android:mimeType="application/geo+json" />
                <data android:mimeType="application/json" />
                <data android:mimeType="application/xml" />
                <data android:mimeType="text/xml" />
                <data android:mimeType="text/plain" />
                <data android:mimeType="text/csv" />
                <data android:mimeType="application/csv" />
                <data android:mimeType="application/vnd.ms-excel" />
                <data android:mimeType="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" />
                <data android:mimeType="application/vnd.ms-excel.sheet.macroEnabled.12" />
                <data android:mimeType="application/geopackage+sqlite3" />
                <data android:mimeType="application/x-sqlite3" />
                <data android:mimeType="application/vnd.sqlite3" />
                <data android:mimeType="application/x-mbtiles" />
                <data android:mimeType="image/tiff" />
                <data android:mimeType="application/zip" />
                <data android:mimeType="application/x-zip-compressed" />
                <data android:mimeType="application/x-zip" />
                <data android:mimeType="application/x-shapefile" />
                <data android:mimeType="application/x-gpx+xml" />
                <data android:mimeType="application/x-gpx" />
                <data android:mimeType="application/x-kml" />
                <data android:mimeType="application/vnd.geo+json" />
                <data android:mimeType="application/x-geojson" />
                <data android:mimeType="application/octet-stream" />
                <data android:mimeType="application/vnd.sov.field-package" />
            </intent-filter>
        </activity>

    </application>

</manifest>
